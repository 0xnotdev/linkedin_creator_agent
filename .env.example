# LinkedIn (required)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Google Gemini (required — free at ai.google.dev)
GEMINI_API_KEY=

# Reddit (required — free at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# GitHub (optional, increases rate limits from 10 to 30 requests/min)
GITHUB_TOKEN=

# Unsplash (optional, for post images)
UNSPLASH_ACCESS_KEY=

# === REAL-TIME SEARCH (at least one recommended) ===

# Google Custom Search Engine (free, 100 queries/day)
# Create at: https://programmablesearchengine.google.com/
# Get API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# Currents API (free, 600 requests/day)
# Get key at: https://currentsapi.services/
CURRENTS_API_KEY=

# Schedule
TZ=Asia/Kolkata
POST_SCHEDULE=weekdays  # 'weekdays' | 'daily' | 'custom'
